generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  fulfilled
  shipped
  awaiting_shipment
}

enum Occasion {
  daily
  cny
  valentine
  dragonboat
  moonfest
  christmas
}

enum BoxSet {
  snack
  produce
  bath
  kitchen
  premium
  healing
  outdoor
  ultimate
}

enum BoxColor {
  festive_red
  sakura_pink
  sage_green
  moon_gold
  oat
  linen
}

enum BoxFinish {
  standard
  recycled
  linen
}

enum InvoiceType {
  ELECTRONIC
  COMPANY
  PAPER
}

model Configuration {
  id              String         @id @default(cuid())
  width           Int?
  height          Int?
  imageUrl        String?
  color           BoxColor?
  occasion        Occasion?
  boxSet          BoxSet?       
  finish          BoxFinish      @default(standard)
  decoration      String[]
  croppedImageUrl String?
  hasCard          Boolean  @default(false)
  Order           Order[]
}

model User {
  id        String   @id @default(cuid())
  email     String
  Order     Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                String           @id @default(cuid())
  configurationId   String
  configuration     Configuration    @relation(fields: [configurationId], references: [id])
  user              User             @relation(fields: [userId], references: [id])
  userId            String
  amount            Float
  isPaid            Boolean          @default(false)
  status            OrderStatus      @default(awaiting_shipment)
  shippingAddress   ShippingAddress? @relation(fields: [shippingAddressId], references: [id])
  shippingAddressId String?
  
  invoiceType       InvoiceType      @default(ELECTRONIC)
  invoiceValue      String?          
  companyTitle      String?          

  createdAt         DateTime         @default(now())
  updated           DateTime         @updatedAt
}

model ShippingAddress {
  id          String  @id @default(cuid())
  name        String
  phoneNumber String
  city        String
  district    String
  postalCode  String
  address     String
  orders      Order[]
}